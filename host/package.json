{
  "name": "apl-host",
  "productName": "APL Host",
  "version": "0.3.4",
  "private": true,
  "homepage": "https://github.com/gdgbaroda/gdg-apl-2026",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "npm run bake && concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:web": "vite build",
    "bake": "node scripts/bake-config.cjs",
    "dist": "npm run bake && npm run build:web && electron-builder --mac --dir",
    "dist:dmg": "npm run bake && npm run build:web && electron-builder --mac dmg",
    "dist:zip": "npm run bake && npm run build:web && electron-builder --mac zip",
    "dist:win": "npm run bake && npm run build:web && electron-builder --win zip --x64",
    "dist:linux": "npm run bake && npm run build:web && electron-builder --linux AppImage deb --x64 --publish never",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.gdgbaroda.aplhost",
    "productName": "APL Host",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "gdgbaroda",
      "repo": "gdg-apl-2026"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "shell.html",
      "poster.jpg",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "zip",
          "arch": "x64"
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "maintainer": "GDG Baroda <hardip@anormaly.com>",
      "artifactName": "apl-host-${version}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": "x64"
        },
        {
          "target": "deb",
          "arch": "x64"
        }
      ]
    }
  }
}
